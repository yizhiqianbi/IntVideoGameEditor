generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  credits       Int      @default(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
